{
  "name": "flowsync-mcp-server",
  "version": "1.0.0",
  "description": "FlowSync MCP server — exposes project context tools to GitHub Copilot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=../extension/dist/mcp-server.mjs",
    "start": "node dist/index.js",
    "dev": "node --import tsx/esm --watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
