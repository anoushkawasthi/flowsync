{
  "name": "flowsync",
  "displayName": "FlowSync",
  "description": "FlowSync — Capture, understand, and query your team's dev context with AI",
  "version": "1.0.2",
  "publisher": "vanta-thapar",
  "icon": "assets/logo.png",
  "galleryBanner": {
    "color": "#0f0f0f",
    "theme": "dark"
  },
  "keywords": [
    "ai",
    "context",
    "git",
    "productivity",
    "team",
    "copilot",
    "mcp",
    "knowledge"
  ],
  "categories": [
    "AI",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anoushkawasthi/flowsync"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "activationEvents": [
    "workspaceContains:.flowsync.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flowsync.openPanel",
        "title": "FlowSync: Open Dashboard"
      },
      {
        "command": "flowsync.catchMeUp",
        "title": "FlowSync: Catch Me Up"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "cd ../mcp-server && npm run bundle && cd ../extension && npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vsix": "vsce package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
